# Groq API key (free tier — https://console.groq.com)
GROQ_API_KEY=

# HuggingFace token (optional, free — https://huggingface.co/settings/tokens)
HF_API_TOKEN=

# Data directory (defaults to /app/data when mounted on Railway)
# DATA_DIR=/app/data

# SQLite DB path (defaults to $DATA_DIR/indieaid.db)
# DB_PATH=/app/data/indieaid.db

# Upload directory for report images (defaults to $DATA_DIR/uploads)
# UPLOADS_DIR=/app/data/uploads

# CORS origins — comma-separated (override default list if needed)
# CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]
