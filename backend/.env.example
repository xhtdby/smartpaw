# Groq API key (free tier — https://console.groq.com)
GROQ_API_KEY=

# HuggingFace token (optional, free — https://huggingface.co/settings/tokens)
HF_API_TOKEN=

# Data directory (defaults to /app/data when mounted on Railway)
# DATA_DIR=/app/data
# Railway may also expose a mounted volume path here.
# RAILWAY_VOLUME_MOUNT_PATH=/app/data

# SQLite DB path (defaults to $DATA_DIR/indieaid.db)
# DB_PATH=/app/data/indieaid.db

# Upload directory for report images (defaults to $DATA_DIR/uploads)
# UPLOADS_DIR=/app/data/uploads

# Persistent volume budget guards. Keep soft limit below Railway's 500 MB cap.
# PERSISTENT_STORAGE_BUDGET_MB=500
# PERSISTENT_STORAGE_SOFT_LIMIT_MB=450
# PERSISTENT_STORAGE_MIN_FREE_MB=25

# Stored report images are recompressed to JPEG before disk write.
# STORED_REPORT_IMAGE_MAX_EDGE=960
# STORED_REPORT_IMAGE_QUALITY=68
# STORED_REPORT_IMAGE_TARGET_KB=220
# STORED_REPORT_IMAGE_HARD_MAX_KB=450

# CORS origins — comma-separated (override default list if needed)
# CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]
